generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Buyer {
  id        Int      @id @default(autoincrement())
  name      String
  product   String
  location  String
  createdAt DateTime @default(now())
}

model Seller {
  id        Int      @id @default(autoincrement())
  name      String
  product   String
  location  String
  createdAt DateTime @default(now())
}
